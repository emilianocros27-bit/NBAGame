rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Progreso del juego: solo tu propia cuenta
    match /saves/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Perfiles: cualquiera autenticado puede VER, solo el dueño edita
    match /profiles/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // @usuarios: cualquiera autenticado puede buscar (leer).
    // Crear: solo si reclamas tu propio uid. No se puede pisar el de otro.
    match /usernames/{name} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Amistades: solo los dos implicados pueden leer/escribir
    match /friendships/{pair} {
      allow read: if request.auth != null && request.auth.uid in resource.data.users;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.users;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.users;
    }

    // Intercambios: solo los implicados (campo parties = [from, to])
    match /trades/{id} {
      allow read: if request.auth != null && request.auth.uid in resource.data.parties;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.parties;
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.parties;
    }
  }
}
